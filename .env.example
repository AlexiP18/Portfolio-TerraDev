# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — FRONTEND (Vite)
# Copiar este archivo a `.env.local` y completar los valores reales.
# NUNCA commitear `.env.local` al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ID del proyecto Sanity — obtenlo en https://sanity.io/manage
VITE_SANITY_PROJECT_ID=hhcu69rv

# Dataset (usualmente "production")
VITE_SANITY_DATASET=production

# Versión de la API Sanity (formato YYYY-MM-DD)
# Usar la fecha en la que configuraste el proyecto o una posterior.
VITE_SANITY_API_VERSION=2024-01-01

# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — SANITY STUDIO (carpeta /studio)
# Estas van en /studio/.env o /studio/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# SANITY_STUDIO_PROJECT_ID=your_project_id_here
# SANITY_STUDIO_DATASET=production
